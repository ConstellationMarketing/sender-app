# Copy this to `.env` and fill in.

# Master Supabase project (where sender_* tables live)
SUPABASE_URL=https://cwligyakhxevopxiksdm.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Mailgun — used by POST /api/batches/:id/send to actually deliver email.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.goconstellation.com
MAILGUN_FROM=Constellation Marketing <reports@mg.goconstellation.com>

# Port (defaults to 3010). Avoid 3000 (Meerkat) and 3001 (SPR0).
PORT=3010

# Allowed CORS origins for browser requests. Comma-separated.
ALLOWED_ORIGINS=https://os.goconstellation.com,http://localhost:8788
